
generator client {
  provider = "prisma-client-js"
  engineType = "library"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  SHOP_ADMIN
}

enum PublicPaymentMethod {
  KPAY
  AYA_PAY
  WAVE_PAY
}

enum PublicOrderStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  role               UserRole
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  customers Customer[]
}

model Customer {
  id              String   @id @default(cuid())
  ingameId        String
  zoneId          String
  shopAdminUserId String
  shopAdmin       User     @relation(fields: [shopAdminUserId], references: [id], onDelete: Cascade)
  orders          Order[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shopAdminUserId])
  @@index([ingameId, zoneId])
}

model OrderType {
  id           String   @id @default(cuid())
  type         String
  buyingPrice  Decimal  @default(0) @db.Decimal(14, 2)
  sellingPrice Decimal  @default(0) @db.Decimal(14, 2)
  isActive     Boolean  @default(true)
  orders       Order[]
  publicOrders PublicOrder[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PublicPaymentAccount {
  id            String              @id @default(cuid())
  method        PublicPaymentMethod @unique
  accountName   String
  accountNumber String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Order {
  id           String    @id @default(cuid())
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderTypeId  String
  orderType    OrderType @relation(fields: [orderTypeId], references: [id])
  orderDate    DateTime  @default(now())
  buyingPrice  Decimal   @db.Decimal(14, 2)
  sellingPrice Decimal   @db.Decimal(14, 2)
  netProfit    Decimal   @db.Decimal(14, 2)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([customerId])
  @@index([orderTypeId])
  @@index([orderDate])
}

model PublicOrder {
  id                    String              @id @default(cuid())
  orderTypeId           String
  orderType             OrderType           @relation(fields: [orderTypeId], references: [id])
  ingameId              String
  zoneId                String
  paymentMethod         PublicPaymentMethod
  paymentAccountNameSnapshot String
  paymentNumberSnapshot String
  transactionId         String
  status                PublicOrderStatus   @default(PENDING)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([orderTypeId])
  @@index([createdAt])
  @@index([paymentMethod])
}
